// BunkMaster Pro - Prisma Schema
// Multi-tenant attendance management backend

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// USERS & AUTH
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships       SectionMembership[]
  attendanceRecords AttendanceRecord[]
  pushSubscriptions PushSubscription[]
  cancellationsMade Cancellation[]      @relation("CancellationCreatedBy")
  subjectsCreated   Subject[]           @relation("SubjectCreatedBy")
}

// ---------------------------------------------------------------------------
// SECTIONS (a class/batch, e.g. "CS 3rd Year - Section B - 2026")
// ---------------------------------------------------------------------------

model Section {
  id                String    @id @default(uuid())
  name              String
  joinCode          String    @unique // students use this to enroll
  institutionName   String?
  // Start date of the semester - used as the lower bound when generating
  // AttendanceRecord rows from the timetable. CR/SR can set/update this.
  semesterStartDate DateTime? @db.Date
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  memberships    SectionMembership[]
  subjects       Subject[]
  timetableSlots TimetableSlot[]
  holidays       HolidayCalendar[]
  cancellations  Cancellation[]
}

enum SectionRole {
  student
  cr
  sr
}

model SectionMembership {
  id          String      @id @default(uuid())
  userId      String
  sectionId   String
  role        SectionRole @default(student)
  batchNumber Int         @default(0) // 0-3, which lab batch (1-4) this student belongs to
  joinedAt    DateTime    @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionId])
  @@index([sectionId])
}

// ---------------------------------------------------------------------------
// SUBJECTS
// ---------------------------------------------------------------------------

model Subject {
  id            String   @id @default(uuid())
  sectionId     String
  name          String
  // Optional: total lectures planned for the semester (used for strategy calc)
  semesterTotal Int?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  section           Section            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdBy         User?              @relation("SubjectCreatedBy", fields: [createdById], references: [id])
  timetableSlots    TimetableSlot[]
  labSlots          TimetableLabSlot[]
  attendanceRecords AttendanceRecord[]
  cancellations     Cancellation[]

  @@index([sectionId])
}

// ---------------------------------------------------------------------------
// TIMETABLE
// ---------------------------------------------------------------------------
// dayOfWeek: 0=Mon, 1=Tue, 2=Wed, 3=Thu, 4=Fri
// slotIndex: 0-8, matches the 9 daily slots (one of which is a BREAK)

model TimetableSlot {
  id        String  @id @default(uuid())
  sectionId String
  dayOfWeek Int // 0-4
  slotIndex Int // 0-8
  isBreak   Boolean @default(false)
  subjectId String? // lecture for this slot (whole section)

  section       Section            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject       Subject?           @relation(fields: [subjectId], references: [id])
  labSlots      TimetableLabSlot[]
  cancellations Cancellation[]

  @@unique([sectionId, dayOfWeek, slotIndex])
  @@index([sectionId])
}

// Per-batch lab assignment for a given timetable slot
model TimetableLabSlot {
  id              String  @id @default(uuid())
  timetableSlotId String
  batchNumber     Int // 1-4
  subjectId       String?

  timetableSlot TimetableSlot @relation(fields: [timetableSlotId], references: [id], onDelete: Cascade)
  subject       Subject?      @relation(fields: [subjectId], references: [id])

  @@unique([timetableSlotId, batchNumber])
}

// ---------------------------------------------------------------------------
// HOLIDAYS
// ---------------------------------------------------------------------------

enum HolidayType {
  national
  college
  custom
}

model HolidayCalendar {
  id        String      @id @default(uuid())
  sectionId String
  date      DateTime    @db.Date
  name      String
  type      HolidayType @default(custom)

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, date])
  @@index([sectionId])
}

// ---------------------------------------------------------------------------
// CANCELLATIONS & RESCHEDULES
// ---------------------------------------------------------------------------

enum CancellationStatus {
  cancelled
  rescheduled
}

model Cancellation {
  id              String             @id @default(uuid())
  sectionId       String
  date            DateTime           @db.Date
  timetableSlotId String
  subjectId       String
  reason          String?
  status          CancellationStatus @default(cancelled)
  createdById     String

  // Reschedule target (filled when status = rescheduled)
  rescheduledDate            DateTime? @db.Date
  rescheduledTimetableSlotId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section       Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  timetableSlot TimetableSlot @relation(fields: [timetableSlotId], references: [id])
  subject       Subject       @relation(fields: [subjectId], references: [id])
  createdBy     User          @relation("CancellationCreatedBy", fields: [createdById], references: [id])

  @@index([sectionId, date])
}

// ---------------------------------------------------------------------------
// ATTENDANCE RECORDS (per-student, per-subject, per-date)
// ---------------------------------------------------------------------------

enum AttendanceStatus {
  attended
  missed
  cancelled // lecture didn't happen, doesn't count toward total
  not_yet_occurred
}

model AttendanceRecord {
  id              String           @id @default(uuid())
  userId          String
  subjectId       String
  date            DateTime         @db.Date
  status          AttendanceStatus @default(not_yet_occurred)
  // which timetable slot this record corresponds to (for traceability)
  timetableSlotId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId, date, timetableSlotId])
  @@index([userId, subjectId])
}

// ---------------------------------------------------------------------------
// PUSH NOTIFICATIONS (Phase 4)
// ---------------------------------------------------------------------------

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
