# PostgreSQL connection string
# Example for local Postgres: postgresql://postgres:password@localhost:5432/bunkmaster
# Example for hosted (Supabase/Neon/Railway): provided by the platform
DATABASE_URL="postgresql://user:password@localhost:5432/bunkmaster?schema=public"

# JWT secret - use a long random string in production
JWT_SECRET="replace-this-with-a-long-random-secret-string"

# JWT expiry (e.g. "7d", "12h")
JWT_EXPIRES_IN="7d"

# Server port
PORT=4000

# Allowed origin for CORS (your frontend URL)
CORS_ORIGIN="http://localhost:5173"
